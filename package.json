{
  "name": "inspectr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "tsx -r dotenv/config scripts/migrate.ts dotenv_config_path=.env.local dotenv_config_override=true",
    "db:storage": "tsx -r dotenv/config scripts/setup-storage.ts dotenv_config_path=.env.local dotenv_config_override=true",
    "db:find-region": "tsx scripts/find-region.ts",
    "benchmark": "tsx -r dotenv/config scripts/benchmark.ts dotenv_config_path=.env.local dotenv_config_override=true",
    "seed:demo": "tsx -r dotenv/config scripts/seed-demo-inspection.ts dotenv_config_path=.env.local dotenv_config_override=true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.3",
